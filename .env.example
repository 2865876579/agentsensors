# 服务配置
TIMEZONE=Asia/Shanghai
LOCATION=重庆
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 网易云音乐配置
# 从浏览器请求头复制完整 cookie，填到本地/服务器 .env；不要提交到仓库。
NETEASE_COOKIE=your_netease_cookie
NETEASE_BR=320000
NETEASE_MAX_PLAY_SECONDS=360

# 邮箱配置（163/QQ IMAP）
# EMAIL_HOST=imap.163.com
# EMAIL_USER=your_email@163.com
# EMAIL_PASS=your_imap_auth_code
